{
  "name": "project-management",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "node_modules/node/bin/node node_modules/vite/bin/vite.js",
    "get-going": "node scripts/get-going.mjs",
    "all-done": "node scripts/all-done.mjs",
    "build": "node_modules/node/bin/node node_modules/typescript/bin/tsc -b && node_modules/node/bin/node node_modules/vite/bin/vite.js build",
    "build:netlify": "node scripts/build-netlify.mjs",
    "preview": "node_modules/node/bin/node node_modules/vite/bin/vite.js preview",
    "lint": "node_modules/node/bin/node node_modules/typescript/bin/tsc -b",
    "test": "node_modules/node/bin/node node_modules/vitest/vitest.mjs run",
    "test:security": "node_modules/node/bin/node node_modules/vitest/vitest.mjs run --config vitest.security.config.ts",
    "test:visual": "node_modules/node/bin/node node_modules/@playwright/test/cli.js test",
    "supabase:start": "supabase start",
    "supabase:stop": "supabase stop",
    "supabase:status": "supabase status",
    "supabase:reset": "supabase db reset",
    "supabase:migration": "supabase db diff --local --file",
    "supabase:functions:serve": "supabase functions serve",
    "supabase:functions:deploy": "supabase functions deploy"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.108.1",
    "@vitejs/plugin-react": "latest",
    "lucide-react": "^1.21.0",
    "react": "latest",
    "react-dom": "latest",
    "react-router-dom": "latest",
    "sass": "latest",
    "typescript": "latest",
    "vite": "latest"
  },
  "devDependencies": {
    "@playwright/test": "latest",
    "@types/node": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "node": "22.23.1",
    "supabase": "^2.105.0",
    "vitest": "latest"
  }
}
